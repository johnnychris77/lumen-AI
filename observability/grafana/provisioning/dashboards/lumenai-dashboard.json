{
  "schemaVersion": 38,
  "title": "LumenAI API",
  "tags": ["lumenai"],
  "timezone": "browser",
  "panels": [
    {
      "type": "timeseries",
      "title": "Predictions Total (rate)",
      "gridPos": {"x": 0, "y": 0, "w": 12, "h": 8},
      "targets": [
        {"expr": "sum(rate(lumenai_predictions_total[1m]))", "legendFormat": "rps"}
      ]
    },
    {
      "type": "timeseries",
      "title": "Latency p95",
      "gridPos": {"x": 12, "y": 0, "w": 12, "h": 8},
      "targets": [
        {"expr": "histogram_quantile(0.95, sum(rate(lumenai_prediction_latency_seconds_bucket[5m])) by (le))", "legendFormat": "p95"}
      ]
    },
    {
      "type": "timeseries",
      "title": "Predictions by Status (rate)",
      "gridPos": {"x": 0, "y": 8, "w": 24, "h": 8},
      "targets": [
        {"expr": "sum by (status) (rate(lumenai_predictions_total[1m]))", "legendFormat": "{{status}}"}
      ]
    }
  ],
  "templating": {"list": []},
  "annotations": {"list": []}
}
