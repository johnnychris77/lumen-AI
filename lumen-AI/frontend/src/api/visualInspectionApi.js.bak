const API_HOST = window.location.hostname;
const API_BASE_URL =
  import.meta.env.VITE_API_BASE_URL || `http://${API_HOST}:18121`;

async function handleResponse(response, label) {
  if (!response.ok) {
    const details = await response.text();
    throw new Error(`${label}: ${response.status} ${details}`);
  }

  return response.json();
}

export async function analyzeVisualInspection(payload) {
  const response = await fetch(`${API_BASE_URL}/api/inspection-review/analyze`, {
    method: "POST",
    headers: {
      "Content-Type": "application/json",
      Authorization: "Bearer dev-token",
      "X-Tenant-Id": "bonsecours",
      "X-Tenant-Name": "Bon Secours",
    },
    body: JSON.stringify(payload),
  });

  return handleResponse(response, "Failed to analyze visual inspection");
}

export async function fetchVisualInspectionReviews() {
  const response = await fetch(`${API_BASE_URL}/api/inspection-review/`, {
    headers: {
      Authorization: "Bearer dev-token",
      "X-Tenant-Id": "bonsecours",
      "X-Tenant-Name": "Bon Secours",
    },
  });

  return handleResponse(response, "Failed to fetch visual inspection reviews");
}

export async function finalizeVisualInspectionReview(reviewId, payload) {
  const response = await fetch(`${API_BASE_URL}/api/inspection-review/${reviewId}/finalize`, {
    method: "POST",
    headers: {
      "Content-Type": "application/json",
      Authorization: "Bearer dev-token",
      "X-Tenant-Id": "bonsecours",
      "X-Tenant-Name": "Bon Secours",
    },
    body: JSON.stringify(payload),
  });

  return handleResponse(response, "Failed to finalize visual inspection review");
}

