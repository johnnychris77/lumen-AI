  const response = await fetch(`${API_BASE_URL}/api/evidence/${evidenceId}/link-to-visual-review/${reviewId}`, {
    method: "POST",
    headers: {
      Authorization: "Bearer dev-token",
      "X-Tenant-Id": "bonsecours",
