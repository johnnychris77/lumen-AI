const API_HOST = window.location.hostname;
export const API_BASE_URL =
  import.meta.env.VITE_API_BASE_URL || `http://${API_HOST}:18122`;

async function handleResponse(response, label) {
  if (!response.ok) {
    const details = await response.text();
    throw new Error(`${label}: ${response.status} ${details}`);
  }

  return response.json();
}

export function buildEvidenceFileUrl(fileUrl) {
  if (!fileUrl) return "";
  if (fileUrl.startsWith("http")) return fileUrl;
  return `${API_BASE_URL}${fileUrl}`;
}

export async function uploadEvidence({
  file,
  evidence_type,
  facility,
  instrument_name,
  vendor,
  finding_category,
}) {
  const formData = new FormData();

  formData.append("file", file);
  formData.append("evidence_type", evidence_type || "borescope_image");
  formData.append("facility", facility || "");
  formData.append("instrument_name", instrument_name || "");
  formData.append("vendor", vendor || "");
  formData.append("finding_category", finding_category || "");

  const response = await fetch(`${API_BASE_URL}/api/evidence/upload`, {
    method: "POST",
    headers: {
      Authorization: "Bearer dev-token",
      "X-Tenant-Id": "bonsecours",
      "X-Tenant-Name": "Bon Secours",
    },
    body: formData,
  });

  return handleResponse(response, "Failed to upload evidence");
}

export async function fetchEvidence() {
  const response = await fetch(`${API_BASE_URL}/api/evidence/`, {
    headers: {
      Authorization: "Bearer dev-token",
      "X-Tenant-Id": "bonsecours",
      "X-Tenant-Name": "Bon Secours",
    },
  });

  return handleResponse(response, "Failed to fetch evidence");
}

export async function fetchEvidenceById(evidenceId) {
  const response = await fetch(`${API_BASE_URL}/api/evidence/${evidenceId}`, {
    headers: {
      Authorization: "Bearer dev-token",
      "X-Tenant-Id": "bonsecours",
      "X-Tenant-Name": "Bon Secours",
    },
  });

  return handleResponse(response, "Failed to fetch evidence details");
}

