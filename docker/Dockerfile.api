FROM python:3.11-slim
WORKDIR /app

COPY requirements.txt ./
RUN pip install --no-cache-dir -r requirements.txt

COPY backend ./backend
COPY worker ./worker
COPY ui ./ui

ENV PYTHONPATH=/app/backend
EXPOSE 8000

CMD ["python","-m","uvicorn","lumenai.api.main:app","--host","0.0.0.0","--port","8000"]
