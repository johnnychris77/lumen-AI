# ── API ───────────────────────────────────────────────────────────────────────
# Backend URL. Set this to your deployed backend in staging/production.
VITE_API_BASE_URL=http://localhost:8000

# ── Auth ─────────────────────────────────────────────────────────────────────
# Fallback token used when localStorage has no "token" key.
# For pilot/dev: set to "dev-token" to match AUTH_MODE=dev on the backend.
# For production: leave empty — tokens come from your OIDC login flow.
VITE_AUTH_TOKEN=dev-token
