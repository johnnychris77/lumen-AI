# =========================
# LumenAI Environment Config
# =========================

# Runtime
APP_ENV=development
API_PREFIX=/api
PUBLIC_BASE_URL=http://127.0.0.1:18011

# Auth
# AUTH_MODE=dev   → accepts Bearer dev-token (pilot / local only — NOT for production)
# AUTH_MODE=oidc  → requires a valid JWKS-signed JWT from OIDC_ISSUER_URL
AUTH_MODE=dev
DEV_AUTH_TOKEN=dev-token
ENABLE_DEV_AUTH=true

# OIDC / JWKS (required when AUTH_MODE=oidc)
# OIDC_ISSUER_URL=https://your-idp.example.com/.well-known/openid-configuration
# OIDC_AUDIENCE=lumenai-api
# Set AUTH_MODE=oidc and configure above to enable production JWT validation.

# Database
DATABASE_URL=postgresql+psycopg2://lumen:lumen@db:5432/lumenai

# Scheduler intervals
PORTFOLIO_BRIEFING_SCHEDULER_SECONDS=60
EXECUTIVE_KPI_SCHEDULER_HOURS=24

# Delivery transport
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_TLS=true

# Webhook delivery
DEFAULT_WEBHOOK_URL=

# Artifact roots
PORTFOLIO_BRIEFING_ARTIFACT_ROOT=generated_portfolio_briefings
GOVERNANCE_PACKET_ARTIFACT_ROOT=generated_governance_packets
REPORTS_ROOT=reports

# Security / governance
ENABLE_ENTERPRISE_AUDIT=true
ENABLE_ENTERPRISE_RBAC=true

# CORS
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:4173,http://127.0.0.1:4173,http://localhost:9092,http://127.0.0.1:9092,http://localhost:18011,http://127.0.0.1:18011,https://lumen-ai-53u4.onrender.com
