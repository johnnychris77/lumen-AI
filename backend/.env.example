# =========================
# LumenAI Environment Config
# =========================

# Runtime
APP_ENV=development
API_PREFIX=/api
PUBLIC_BASE_URL=http://127.0.0.1:18011

# Auth
# Development token only. Replace in production.
DEV_AUTH_TOKEN=dev-token
ENABLE_DEV_AUTH=true

# Database
DATABASE_URL=postgresql+psycopg2://lumen:lumen@db:5432/lumenai

# Scheduler intervals
PORTFOLIO_BRIEFING_SCHEDULER_SECONDS=60
EXECUTIVE_KPI_SCHEDULER_HOURS=24

# Delivery transport
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_TLS=true

# Webhook delivery
DEFAULT_WEBHOOK_URL=

# Artifact roots
PORTFOLIO_BRIEFING_ARTIFACT_ROOT=generated_portfolio_briefings
GOVERNANCE_PACKET_ARTIFACT_ROOT=generated_governance_packets
REPORTS_ROOT=reports

# Security / governance
ENABLE_ENTERPRISE_AUDIT=true
ENABLE_ENTERPRISE_RBAC=true

# CORS
ALLOWED_ORIGINS=http://127.0.0.1:18011,http://localhost:18011,http://localhost:5173,http://127.0.0.1:5173,http://localhost:9092,http://127.0.0.1:9092,https://lumen-ai-53u4.onrender.com
